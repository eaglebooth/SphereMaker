{
  "name": "sphere-maker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Autonomous market-making and swap agent for Unicity Sphere Testnet v2.",
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"tsx watch src/server/index.ts\" \"vite --host 127.0.0.1\"",
    "dev:api": "tsx src/server/index.ts",
    "dev:web": "vite --host 127.0.0.1",
    "demo:counterparty": "tsx src/server/demoCounterparty.ts",
    "demo:scenario": "tsx src/server/demoScenario.ts",
    "live:counterparty": "tsx src/server/liveCounterparty.ts",
    "live:counterparty:responder": "tsx src/server/liveCounterpartyResponder.ts",
    "live:scenario": "tsx src/server/liveScenario.ts",
    "build": "tsc && vite build",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@unicitylabs/sphere-sdk": "latest",
    "@vitejs/plugin-react": "latest",
    "concurrently": "latest",
    "cors": "latest",
    "dotenv": "latest",
    "express": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "tsx": "latest",
    "vite": "latest",
    "ws": "^8.21.0",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/cors": "latest",
    "@types/express": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "typescript": "latest"
  }
}
